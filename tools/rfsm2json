#!/usr/bin/env lua
-- -*- lua -*-
local rfsm = require("rfsm")
local rfsm2json = require("rfsm.rfsm2json")
local utils = require("utils")

if arg and #arg < 1 then
   print("usage: rfsm2json <file1> <file2>...")
   os.exit(1)
end

local function fsm2json(file)
   local outfile = string.gsub(file, "\.%w*$", "")
   local fsm_tpl = assert(rfsm.load(file), "failed to open fsm file " .. file)
   local fsm = rfsm.init(fsm_tpl)
   if not fsm then
      print("error: state machine checking failed.")
      os.exit(1)
   end
   io.output(outfile .. ".json")
   io.write(rfsm2json.encode(fsm))
end

arg[-1]=nil; arg[0]=nil;
utils.map(fsm2json, arg)

--io.write(json.encode(fsm_tpl))
os.exit(0)
